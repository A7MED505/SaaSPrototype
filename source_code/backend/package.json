{
  "name": "saas-backend",
  "version": "1.0.0",
  "description": "FirstSaaS E-commerce Backend",
  "main": "app/main.js",
  "scripts": {
    "start": "node app/main.js",
    "dev": "nodemon app/main.js",
    "test": "jest --passWithNoTests",
    "test:unit": "jest test_code/unit_tests/",
    "test:api": "jest test_code/api_tests/",
    "test:bdd": "cucumber-js test_code/bdd_features/",
    "test:coverage": "jest --coverage",
    "test:all": "jest && npm run test:bdd",
    "lint": "eslint app/",
    "format": "prettier --write app/"
  },
  "keywords": ["saas", "ecommerce", "express", "mongodb"],
  "author": "Ahmed",
  "license": "ISC",
  "dependencies": {
    "express": "^4.19.2",
    "mongoose": "^8.4.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.3",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "@cucumber/cucumber": "^9.0.0",
    "eslint": "^8.50.0",
    "prettier": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
